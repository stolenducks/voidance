#!/bin/bash
# droid - Void Linux AI Helper
# Offline AI assistant with Void Linux documentation context

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Paths
DROID_DIR="/opt/droid"
VOID_DOCS="/opt/void-docs"
MODEL_PATH="$DROID_DIR/models/qwen2.5-coder-3b-instruct.Q4_K_M.gguf"
LLAMA_SERVER="http://localhost:8080"
INITIALIZED_FLAG="/var/lib/droid/initialized"

# Helper functions
info() { echo -e "${GREEN}[droid]${NC} $*"; }
warn() { echo -e "${YELLOW}[droid]${NC} $*"; }
error() { echo -e "${RED}[droid]${NC} $*" >&2; }

# Check if llama-server is running
check_llama() {
    if ! command -v llama-server &>/dev/null; then
        error "llama-server is not installed"
        return 1
    fi
    
    if ! sv status llama-server &>/dev/null 2>&1; then
        warn "llama-server service is not running"
        info "Run: droid setup"
        return 1
    fi
    
    # Check if server is responding
    # llama.cpp server responds to /health or root endpoint
    if ! curl -s "$LLAMA_SERVER/health" &>/dev/null && \
       ! curl -s "$LLAMA_SERVER/" &>/dev/null; then
        warn "llama-server is not responding"
        return 1
    fi
    
    return 0
}

# Check if model exists
check_model() {
    if [ ! -f "$MODEL_PATH" ]; then
        error "Model not found at $MODEL_PATH"
        info "Run: droid setup"
        return 1
    fi
    return 0
}

# Setup: ensure llama-server is running
cmd_setup() {
    info "Setting up droid AI helper..."
    
    # Check llama-server installation
    if ! command -v llama-server &>/dev/null; then
        error "llama-server is not installed"
        error "Please install llama.cpp or use the full ISO with AI included"
        return 1
    fi
    
    # Check if model exists
    if [ ! -f "$MODEL_PATH" ]; then
        error "Model not found at $MODEL_PATH"
        error "Please ensure the AI model is properly installed"
        return 1
    fi
    
    # Enable llama-server service if not running
    if ! sv status llama-server &>/dev/null 2>&1; then
        info "Enabling llama-server service..."
        sudo ln -sf /etc/sv/llama-server /var/service/
        sleep 3
    fi
    
    # Wait for llama-server to be ready
    info "Waiting for llama-server to start..."
    for i in {1..15}; do
        # Try /health first, fallback to root endpoint
        if curl -s "$LLAMA_SERVER/health" &>/dev/null || \
           curl -s "$LLAMA_SERVER/" &>/dev/null; then
            info "llama-server is ready!"
            break
        fi
        if [ $i -eq 15 ]; then
            error "llama-server failed to start"
            return 1
        fi
        sleep 1
    done
    
    # Mark as initialized
    sudo mkdir -p "$(dirname "$INITIALIZED_FLAG")"
    sudo touch "$INITIALIZED_FLAG"
    
    info "Setup complete! Try: droid \"your question\""
}

# Status: show current state
cmd_status() {
    echo "=== Droid AI Helper Status ==="
    echo
    
    # llama-server status
    if command -v llama-server &>/dev/null; then
        echo -e "${GREEN}✓${NC} llama-server: installed"
        if sv status llama-server &>/dev/null 2>&1; then
            echo -e "${GREEN}✓${NC} llama-server service: running"
            # Try /health first, fallback to root
            if curl -s "$LLAMA_SERVER/health" &>/dev/null || \
               curl -s "$LLAMA_SERVER/" &>/dev/null; then
                echo -e "${GREEN}✓${NC} llama-server: responding"
            else
                echo -e "${YELLOW}!${NC} llama-server: not responding"
            fi
        else
            echo -e "${RED}✗${NC} llama-server service: not running"
        fi
    else
        echo -e "${RED}✗${NC} llama-server: not installed"
    fi
    
    # Model status
    if [ -f "$MODEL_PATH" ]; then
        model_size=$(du -h "$MODEL_PATH" 2>/dev/null | cut -f1)
        echo -e "${GREEN}✓${NC} model: present ($model_size)"
    else
        echo -e "${RED}✗${NC} model: not found"
    fi
    
    # Docs status
    if [ -d "$VOID_DOCS" ]; then
        doc_size=$(du -sh "$VOID_DOCS" 2>/dev/null | cut -f1)
        echo -e "${GREEN}✓${NC} void docs: $doc_size"
    else
        echo -e "${YELLOW}!${NC} void docs: not found"
    fi
    
    # Initialization status
    if [ -f "$INITIALIZED_FLAG" ]; then
        echo -e "${GREEN}✓${NC} initialized: yes"
    else
        echo -e "${YELLOW}!${NC} initialized: no (run: droid setup)"
    fi
}

# Query the AI with context
cmd_query() {
    local question="$*"
    
    if [ -z "$question" ]; then
        error "Please provide a question"
        echo "Usage: droid \"your question\""
        return 1
    fi
    
    # Check prerequisites
    check_llama || return 1
    check_model || return 1
    
    # Extract relevant context from Void docs if available
    local context=""
    if [ -d "$VOID_DOCS" ] && command -v rg &>/dev/null; then
        # Search for relevant documentation snippets
        context=$(rg -i --max-count=3 --no-line-number --no-filename \
            "$question" "$VOID_DOCS" 2>/dev/null | head -n 10 || true)
    fi
    
    # Build prompt with context
    local user_prompt="Question: $question"
    if [ -n "$context" ]; then
        user_prompt="$user_prompt\n\nRelevant Void Linux documentation:\n$context"
    fi
    
    # System prompt (matches our Modelfile/server config)
    local system_prompt="You are a helpful AI assistant specialized in Void Linux system administration and command-line operations. Provide concise, actionable CLI commands. Prefer xbps and runit (NOT systemd). Always prioritize safety."
    
    # Query the llama-server via HTTP API
    curl -s "$LLAMA_SERVER/v1/chat/completions" \
        -H "Content-Type: application/json" \
        -d "{
            \"messages\": [
                {\"role\": \"system\", \"content\": \"$system_prompt\"},
                {\"role\": \"user\", \"content\": \"$user_prompt\"}
            ],
            \"temperature\": 0.3,
            \"max_tokens\": 500
        }" | jq -r '.choices[0].message.content' 2>/dev/null || {
        error "Failed to get response from llama-server"
        return 1
    }
}

# Update documentation mirror
cmd_update_docs() {
    info "Updating Void Linux documentation..."
    
    if ! command -v wget &>/dev/null; then
        error "wget is required for documentation updates"
        return 1
    fi
    
    # Create docs directory
    sudo mkdir -p "$VOID_DOCS"
    
    # Mirror docs (HTML only, no images/CSS to save space)
    info "Downloading docs.voidlinux.org..."
    sudo wget -r -np -nH -R "*.jpg,*.jpeg,*.png,*.gif,*.css,*.js" \
        --cut-dirs=0 -P "$VOID_DOCS" \
        https://docs.voidlinux.org/ 2>&1 | grep -E "(saved|URL:)" || true
    
    info "Documentation updated!"
}

# Uninstall: remove all AI components
cmd_uninstall() {
    warn "This will remove the droid AI helper and reclaim disk space"
    echo
    
    # Calculate current usage
    local total_size=0
    [ -d "$DROID_DIR" ] && total_size=$((total_size + $(du -sb "$DROID_DIR" 2>/dev/null | cut -f1 || echo 0)))
    [ -d "$VOID_DOCS" ] && total_size=$((total_size + $(du -sb "$VOID_DOCS" 2>/dev/null | cut -f1 || echo 0)))
    
    echo "Disk space to be reclaimed: $(numfmt --to=iec $total_size 2>/dev/null || echo "~2-3GB")"
    echo
    read -p "Continue? (y/N): " -n 1 -r
    echo
    
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        info "Uninstall cancelled"
        return 0
    fi
    
    info "Stopping llama-server service..."
    sudo sv stop llama-server 2>/dev/null || true
    sudo rm -f /var/service/llama-server
    
    info "Removing AI assets..."
    sudo rm -rf "$DROID_DIR"
    sudo rm -rf "$VOID_DOCS"
    sudo rm -rf /var/lib/droid
    sudo rm -rf /etc/sv/droid-firstboot
    sudo rm -rf /etc/sv/llama-server
    
    echo
    read -p "Remove llama-server binary? (y/N): " -n 1 -r
    echo
    
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        info "Removing llama-server binary..."
        sudo rm -f /usr/local/bin/llama-server || true
    fi
    
    info "Uninstall complete! System is now near-stock."
    info "The 'droid' command will remain as a small stub."
}

# Show help
cmd_help() {
    cat <<EOF
droid - Void Linux AI Helper (Offline)

USAGE:
    droid "your question"       Ask the AI a question
    droid status                Show system status
    droid setup                 Initialize AI helper (first-time setup)
    droid update-docs           Update Void Linux documentation mirror
    droid uninstall             Remove AI helper and reclaim space
    droid help                  Show this help

EXAMPLES:
    droid "how do I install firefox"
    droid "what is the command to remove a file"
    droid "how do I connect to wifi"
    droid "restart network manager"

NOTES:
    - Works completely offline after initial setup
    - Uses Qwen 2.5 Coder 3B via llama.cpp
    - Includes Void Linux documentation context
    - To remove and go lightweight: droid uninstall

VERSION: 1.0.0 (Void Linux XFCE - AI Edition)
INFERENCE: llama.cpp (MIT License, Independent)
EOF
}

# Main command router
main() {
    if [ $# -eq 0 ]; then
        cmd_help
        return 0
    fi
    
    case "$1" in
        status)
            cmd_status
            ;;
        setup)
            cmd_setup
            ;;
        update-docs)
            cmd_update_docs
            ;;
        uninstall)
            cmd_uninstall
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            # Treat everything else as a query
            cmd_query "$@"
            ;;
    esac
}

main "$@"
