#!/bin/bash
# droid-firstboot - One-time setup service for AI helper
# Runs once on first boot to initialize llama-server

set -euo pipefail

INITIALIZED_FLAG="/var/lib/droid/initialized"
DROID_DIR="/opt/droid"
MODEL_PATH="$DROID_DIR/models/qwen2.5-coder-3b-instruct.Q4_K_M.gguf"
LLAMA_SERVER="http://localhost:8080"

# Log function
log() {
    logger -t droid-firstboot "$*"
    echo "[droid-firstboot] $*"
}

# Check if already initialized
if [ -f "$INITIALIZED_FLAG" ]; then
    log "Already initialized, exiting"
    # Remove ourselves from /var/service
    rm -f /var/service/droid-firstboot
    exit 0
fi

log "Initializing droid AI helper..."

# Ensure llama-server service exists
if [ ! -d /etc/sv/llama-server ]; then
    log "ERROR: llama-server service not found"
    exit 1
fi

# Check if model exists
if [ ! -f "$MODEL_PATH" ]; then
    log "ERROR: Model not found at $MODEL_PATH"
    exit 1
fi

# Enable llama-server service
if [ ! -L /var/service/llama-server ]; then
    log "Enabling llama-server service..."
    ln -sf /etc/sv/llama-server /var/service/
fi

# Wait for llama-server to be ready (max 30 seconds)
log "Waiting for llama-server to start..."
for i in {1..30}; do
    if curl -s "$LLAMA_SERVER/health" &>/dev/null 2>&1; then
        log "llama-server is ready"
        break
    fi
    if [ $i -eq 30 ]; then
        log "ERROR: llama-server failed to start within 30 seconds"
        exit 1
    fi
    sleep 1
done

# Test the model with a simple query
log "Testing model..."
if curl -s "$LLAMA_SERVER/v1/chat/completions" \
    -H "Content-Type: application/json" \
    -d '{"messages":[{"role":"user","content":"test"}],"max_tokens":5}' \
    &>/dev/null; then
    log "Model responding successfully"
else
    log "WARNING: Model test failed, but continuing"
fi

# Mark as initialized
mkdir -p "$(dirname "$INITIALIZED_FLAG")"
touch "$INITIALIZED_FLAG"

log "Initialization complete!"
log "Users can now run: droid \"your question\""

# Remove ourselves from /var/service so we don't run again
rm -f /var/service/droid-firstboot

exit 0
